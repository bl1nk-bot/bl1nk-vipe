{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vibe-coding-agent.example.com/schemas/workflow.schema.json",
  "title": "Workflow",
  "description": "Workflow orchestration schema for managing multi-step agent workflows",
  "type": "object",
  "properties": {
    "workflowId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the workflow"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "description": "Human-readable name of the workflow"
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Description of what the workflow does"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "running", "paused", "completed", "failed", "cancelled"],
      "description": "Current status of the workflow"
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/step"
      },
      "minItems": 1,
      "description": "Ordered list of workflow steps"
    },
    "currentStep": {
      "type": "integer",
      "minimum": 0,
      "description": "Index of the currently executing step"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the workflow was created"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the workflow was last updated"
    },
    "startedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the workflow started execution"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the workflow completed"
    },
    "sessionId": {
      "type": "string",
      "description": "Reference to the associated session"
    },
    "trigger": {
      "$ref": "#/definitions/trigger",
      "description": "What triggered this workflow"
    },
    "error": {
      "$ref": "#/definitions/error",
      "description": "Error information if the workflow failed"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Additional workflow metadata"
    }
  },
  "required": ["workflowId", "name", "status", "steps", "createdAt", "updatedAt"],
  "definitions": {
    "step": {
      "type": "object",
      "properties": {
        "stepId": {
          "type": "string",
          "description": "Unique identifier for the step within the workflow"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable name of the step"
        },
        "description": {
          "type": "string",
          "description": "Description of what this step does"
        },
        "type": {
          "type": "string",
          "enum": [
            "create_sandbox",
            "generate_files",
            "run_command",
            "get_sandbox_url",
            "wait",
            "condition",
            "parallel",
            "loop",
            "human_approval"
          ],
          "description": "Type of action this step performs"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "running", "completed", "failed", "skipped"],
          "description": "Status of this step"
        },
        "order": {
          "type": "integer",
          "minimum": 0,
          "description": "Execution order of this step"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of stepIds that must complete before this step can run"
        },
        "input": {
          "type": "object",
          "description": "Input parameters for the step"
        },
        "output": {
          "type": "object",
          "description": "Output from the step execution"
        },
        "timeout": {
          "type": "integer",
          "minimum": 0,
          "description": "Timeout in milliseconds for this step"
        },
        "retries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10,
          "description": "Number of retry attempts allowed"
        },
        "retryCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Current retry count"
        },
        "startedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the step started execution"
        },
        "completedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the step completed"
        },
        "duration": {
          "type": "number",
          "minimum": 0,
          "description": "Duration of step execution in milliseconds"
        },
        "error": {
          "$ref": "#/definitions/error",
          "description": "Error information if the step failed"
        },
        "condition": {
          "$ref": "#/definitions/condition",
          "description": "Condition for conditional steps"
        },
        "parallelSteps": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/step"
          },
          "description": "Steps to run in parallel for parallel type"
        },
        "loopConfig": {
          "$ref": "#/definitions/loopConfig",
          "description": "Loop configuration for loop type"
        }
      },
      "required": ["stepId", "name", "type", "status", "order"]
    },
    "condition": {
      "type": "object",
      "properties": {
        "expression": {
          "type": "string",
          "description": "Boolean expression to evaluate"
        },
        "variables": {
          "type": "object",
          "additionalProperties": true,
          "description": "Variables available in the expression"
        },
        "trueStep": {
          "type": "string",
          "description": "StepId to execute if condition is true"
        },
        "falseStep": {
          "type": "string",
          "description": "StepId to execute if condition is false"
        }
      },
      "required": ["expression"]
    },
    "loopConfig": {
      "type": "object",
      "properties": {
        "iteratorVariable": {
          "type": "string",
          "description": "Name of the loop iterator variable"
        },
        "items": {
          "type": "array",
          "description": "Items to iterate over"
        },
        "maxIterations": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum number of iterations"
        },
        "templateStep": {
          "$ref": "#/definitions/step",
          "description": "Step template to execute for each item"
        }
      },
      "required": ["items", "templateStep"]
    },
    "trigger": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["manual", "webhook", "schedule", "event", "api"],
          "description": "Type of trigger that started the workflow"
        },
        "source": {
          "type": "string",
          "description": "Source of the trigger (e.g., user ID, webhook URL)"
        },
        "payload": {
          "type": "object",
          "description": "Data passed with the trigger"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the trigger occurred"
        }
      },
      "required": ["type", "timestamp"]
    },
    "error": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "description": "Error message"
        },
        "code": {
          "type": "string",
          "description": "Error code"
        },
        "stepId": {
          "type": "string",
          "description": "StepId where the error occurred"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the error occurred"
        },
        "recoverable": {
          "type": "boolean",
          "description": "Whether the error is recoverable"
        }
      },
      "required": ["message"]
    }
  }
}
